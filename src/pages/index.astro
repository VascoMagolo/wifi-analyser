---
import Simulator from "../components/simulador.jsx";
import "../styles/global.css";
---

<html lang="pt">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Simulador Wi-Fi Indoor</title>
	</head>
	<body class="min-h-screen bg-slate-100 p-4 md:p-8 text-slate-800 antialiased">
		<main class="max-w-4xl mx-auto space-y-6">
			<header>
				<h1 class="text-3xl font-bold text-blue-600">Simulador de Propagação Indoor</h1>
			</header>
			<Simulator client:load />

		</main>
	</body>
</html>